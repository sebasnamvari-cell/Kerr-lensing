#%%Cintura en la cavidad


def calcular_q_ml_para_config(delta, Z, kerr_fwd, kerr_bwd, modo, usar_ml_prev=False):
    """
    Calcula q_CW y q_ML para un delta y una configuracion dada.
    Devuelve: q_cw, q_ml
    """
    M_in, M_mid, M_close = matrices_ml(Z, delta)
    q_cw = q_from_M(matriz_cw(delta))

    # Usamos q_CW como semilla inicial
    q_ml, _ = _iterar(
        q_cw, M_in, M_mid, M_close,
        kerr_fwd, kerr_bwd, modo,
        guardar_historial=False
    )

    return q_cw, q_ml


def graficar_perfil_cavidad_metodos(delta, Z, configs, titulo_general=''):
    """
    Grafica el perfil de cintura a lo largo de la cavidad para cada metodo
    de la lista configs, manteniendo el mismo delta y Z.
    """
    E1 = mirror(f1)
    E2 = mirror(f2)

    # Elementos fijos de la cavidad
    D_T1 = f1 - d/2 + Z
    D_T2 = f2 + delta - d/2 - Z

    elementos = [
        ('EM1',     np.eye(2),     0),
        ('L1',      free(L1),      L1),
        ('E1',      E1,            0),
        ('D_T1',    free(D_T1),    D_T1),
        ('cristal', free(d),       d),
        ('D_T2',    free(D_T2),    D_T2),
        ('E2',      E2,            0),
        ('L2',      free(L2),      L2),
        ('EM2',     np.eye(2),     0),
        ('L2',      free(L2),      L2),
        ('E2',      E2,            0),
        ('D_T2',    free(D_T2),    D_T2),
        ('cristal', free(d),       d),
        ('D_T1',    free(D_T1),    D_T1),
        ('E1',      E1,            0),
        ('L1',      free(L1),      L1),
        ('EM1',     np.eye(2),     0),
    ]

    n = len(configs)
    fig, axes = plt.subplots(n, 1, figsize=(13, 3.2 * n), sharex=True)
    if n == 1:
        axes = [axes]

    for ax, (nombre, kfwd, kbwd, modo, ml_prev) in zip(axes, configs):
        q_cw, q_ml = calcular_q_ml_para_config(delta, Z, kfwd, kbwd, modo, ml_prev)

        z_vals = []
        w_cw_z = []
        w_ml_z = []
        z_actual = 0.0

        q_c = q_cw
        q_m = q_ml

        for _, M, longitud in elementos:
            z_vals.append(z_actual)

            wc = w_from_q(q_c)
            wm = w_from_q(q_m)

            w_cw_z.append(wc * 10 if np.isfinite(wc) else np.nan)  # mm
            w_ml_z.append(wm * 10 if np.isfinite(wm) else np.nan)  # mm

            q_c = prop_q(q_c, M)
            if q_m is not None and q_valido(q_m):
                q_m = prop_q(q_m, M)
            else:
                q_m = np.nan

            z_actual += longitud

        z_vals = np.array(z_vals)
        w_cw_z = np.array(w_cw_z, dtype=float)
        w_ml_z = np.array(w_ml_z, dtype=float)

        ax.plot(z_vals, w_cw_z, color='steelblue', lw=2, label='CW')
        ax.plot(z_vals, w_ml_z, color='tomato', lw=2, label='ML', alpha=0.85)

        ax.fill_between(
            z_vals, w_cw_z, w_ml_z,
            where=(w_ml_z >= w_cw_z),
            alpha=0.2, color='tomato'
        )
        ax.fill_between(
            z_vals, w_cw_z, w_ml_z,
            where=(w_ml_z < w_cw_z),
            alpha=0.2, color='steelblue'
        )

        # Marcar cristal ida y vuelta
        z_cristal_ida = L1 + D_T1
        z_cristal_vuelta = L1 + D_T1 + d + D_T2 + L2 + L2 + D_T2
        ax.axvspan(z_cristal_ida, z_cristal_ida + d, alpha=0.15, color='green')
        ax.axvspan(z_cristal_vuelta, z_cristal_vuelta + d, alpha=0.15, color='green')

        ax.set_ylabel(r'$w$ [mm]')
        ax.set_title(nombre)
        ax.grid(True, linestyle=':')
        ax.legend(loc='best')

    axes[-1].set_xlabel('Posición en la cavidad [cm]')
    fig.suptitle(
        f'{titulo_general}\n'
        f'delta = {delta:.5f} cm   |   Z = {Z:.3f} cm   |   K = {K}',
        y=0.995
    )
    plt.tight_layout()
    plt.show()




