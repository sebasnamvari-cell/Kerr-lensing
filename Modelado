import numpy as np
import matplotlib.pyplot as plt

#%% Parametros


f1  = 7.5
f2  = 7.5
L1  = 30.0
L2  = 40.0
lam = 1027e-7
Lc  = 0.5
d   = Lc
K   = 0.1

Z_a = 0.0
Z_b = 0.35

slices = 200

delta1 = f2**2 / (L2 - f2)

TOL = 1e-8

#%% Matrices de propagacion

def free(x):
    return np.array([[1.0, x], [0.0, 1.0]]) #Propagación libre

def mirror(f):
    return np.array([[1.0, 0.0], [-1.0/f, 1.0]]) #Espejo de foco f

def prop_q(q, M):
    A, B, C, D = M[0,0], M[0,1], M[1,0], M[1,1] #Propagación de q con matrices 
    return (A*q + B) / (C*q + D)

def w_from_q(q):
    try:
        im = np.imag(1.0/q)
        if im >= 0:
            return np.nan #Si la parte imaginaria se hace negativo se cancela la cintura
        return np.sqrt(-lam / (np.pi * im))
    except:
        return np.nan

def q_valido(q): #Solo le pido que no diverjan estas cosas
    try:
        return np.isfinite(q.real) and np.isfinite(q.imag) and np.imag(1.0/q) < 0
    except:
        return False

def q_from_M(Mat): #A partir de M calculo q como dice el apunte de Larrotonda
    A, B, D = Mat[0,0], Mat[0,1], Mat[1,1]
    disc = (A + D)**2 / 4
    if disc >= 1:
        return np.nan
    return B / ((D - A)/2 - 1j*np.sqrt(1 - disc))

def _guess_safe():
    """
    Devuelve q_CW en el ultimo punto estable antes de delta1.
    Solo se usa cuando delta > delta1 y no hay q_ml_prev.
    """
    E1  = mirror(f1)
    E2  = mirror(f2)
    eps = delta1 * 0.01   # 1% antes de delta1
    ds  = free(f1 + f2 + delta1 - eps)
    Ms  = free(L1) @ E1 @ ds @ E2 @ free(L2) @ free(L2) @ E2 @ ds @ E1 @ free(L1)
    return q_from_M(Ms)

def matriz_cw(delta): #Me calcula CW a partir del delta
    E1 = mirror(f1); E2 = mirror(f2)
    dist = free(f1 + f2 + delta)
    return free(L1) @ E1 @ dist @ E2 @ free(L2) @ free(L2) @ E2 @ dist @ E1 @ free(L1)

def matrices_ml(Z, delta): #Calculo todas las matrices del ML salvo las de dentro del cristal
    E1 = mirror(f1); E2 = mirror(f2)
    D_T1 = f1 - d/2 + Z
    D_T2 = f2 + delta - d/2 - Z 
    #Lo que hago es alargar el brazo de la lente 2 manteniendo rígido la distancia del curvo y el plano
    M_in    = free(D_T1) @ E1 @ free(L1)
    M_mid   = free(D_T2) @ E2 @ free(L2) @ free(L2) @ E2 @ free(D_T2)
    M_close = free(L1) @ E1 @ free(D_T1)
    return M_in, M_mid, M_close 

def producto_stack(M_list):
    """Producto matricial en el orden fisico de propagacion."""
    M = np.eye(2)
    for Mi in M_list:
        M = Mi @ M
    return M

def _iterar(q_guess, M_in, M_mid, M_close, kerr_fwd_func, kerr_bwd_func, modo, guardar_historial=False):
    q = q_guess
    alfa = 0.05  # <--- FACTOR DE RELAJACIÓN: Evita que el haz "salte" a otra solución
    max_iter = 1000
    q_ultimo = q
    historial = []

    for i in range(max_iter):
        if not q_valido(q): break
        
        # Propagación según el modo (tu lógica actual está bien)
        q_in_fwd = prop_q(q, M_in)
        if modo == 'propaga':
            Mk_fwd, q_fwd = kerr_fwd_func(q_in_fwd)
            q_in_bwd = prop_q(q_fwd, M_mid)
            Mk_bwd, q_bwd = kerr_bwd_func(q_in_bwd)
            q_target = prop_q(q_bwd, M_close) # Este es el q que "quiere" la cavidad
        else:
            Mk_fwd, _, M_list = kerr_fetas_con_lista(q_in_fwd)
            Mk_bwd, _ = kerr_fetas_bwd(None, M_list=M_list)
            M_total = M_close @ Mk_bwd @ M_mid @ Mk_fwd @ M_in
            q_target = q_from_M(M_total)

        if not q_valido(q_target): break

        # APLICAMOS RELAJACIÓN
        q_new = q + alfa * (q_target - q)
        
        if guardar_historial:
            w = w_from_q(q_new)
            historial.append(w * 10 if np.isfinite(w) else np.nan)

        if abs(q_new - q) < 1e-9: # Tolerancia fina
            q_ultimo = q_new
            break
            
        q = q_new
        q_ultimo = q

    return q_ultimo, historial

#%% Modelos lente Kerr

def kerr_lente_fina(q_in): #Calculo para una lente fina
    if not q_valido(q_in): return None, None #Si no vale q no hagás nada
    w = w_from_q(q_in) #Calculo w
    if np.isnan(w) or w <= 0: return None, None
    f_NL  = (np.pi**2 * w**4) / (K * lam**2 * Lc) #Definición del foco no-lineal con K
    M     = np.array([[1.0, 0.0], [-1.0/f_NL, 1.0]]) #Matriz no-lineal
    return M, prop_q(q_in, M)

def kerr_fetas_fwd(q_in): #  q --> () ---> q'
    if not q_valido(q_in): return None, None
    l = Lc / slices #Tamaño de cada slice
    #Calculo como es inicialmente
    M_acum = np.eye(2); q = q_in 
    M_half = free(l/2)
    q = prop_q(q, M_half); M_acum = M_half @ M_acum
    
    for i in range(slices):
        w = w_from_q(q)
        if np.isnan(w) or w <= 0: return None, None
        f_NL = (np.pi**2 * w**4) / (K * lam**2 * l)
        Ml   = np.array([[1.0, 0.0], [-1.0/f_NL, 1.0]])
        
        q = prop_q(q, Ml)
        M_acum = Ml @ M_acum #q va a ser propagar por la lente
        
        #Ahora propago libremente por el tamaño del slice
        if i < slices - 1:
            q = prop_q(q, free(l))
            M_acum = free(l) @ M_acum #Voy reemplazando la matriz para hallar la matriz entera
    
    q = prop_q(q, M_half)
    M_acum = M_half @ M_acum #Cuando termina tomo medio tamaño de distancia y listo!
    
    return M_acum, q

def kerr_fetas_bwd(q_in, M_list = None): #   q' <--- () <--- q 
    if M_list is not None:
        # Usar las lentes del fwd en orden inverso
        return producto_stack(list(reversed(M_list))), None

   
    if not q_valido(q_in): return None, None
    l = Lc / slices
    M_acum = np.eye(2)
    q = q_in
    M_half = free(l/2) #Igual que antes
    
    q = prop_q(q, M_half); M_acum = M_half @ M_acum
    
    for i in range(slices - 1, -1, -1): #Va haciendo pasos para atras
        w = w_from_q(q)
        if np.isnan(w) or w <= 0: return None, None
        
        f_NL = (np.pi**2 * w**4) / (K * lam**2 * l)
        Ml   = np.array([[1.0, 0.0], [-1.0/f_NL, 1.0]])
        q = prop_q(q, Ml)
        M_acum = Ml @ M_acum
        
        if i > 0:
            q = prop_q(q, free(l))
            M_acum = free(l) @ M_acum
            
    q = prop_q(q, M_half)
    M_acum = M_half @ M_acum
    return M_acum, q

def kerr_fetas_con_lista(q_in):
    """
    Igual que kerr_fetas_fwd pero devuelve ademas M_list
    para poder invertir el orden en bwd.
    """
    if not q_valido(q_in): return None, None, None
    l = Lc / slices
    M_acum = np.eye(2); q = q_in
    M_list = []
    M_half = free(l/2)
    q = prop_q(q, M_half); M_list.append(M_half)
    for i in range(slices):
        w = w_from_q(q)
        if np.isnan(w) or w <= 0: return None, None, None
        f_NL = (np.pi**2 * w**4) / (K * lam**2 * l)
        Ml   = np.array([[1.0, 0.0], [-1.0/f_NL, 1.0]])
        M_list.append(Ml)
        q = prop_q(q, Ml)
        if i < slices - 1:
            M_list.append(free(l))
            q = prop_q(q, free(l))
    q = prop_q(q, M_half); M_list.append(M_half)
    M_acum = producto_stack(M_list)
    return M_acum, q, M_list

def barrer(Z, delta_vals, kerr_fwd, kerr_bwd, modo, usar_ml_prev, nombre=''):
    resolucion = len(delta_vals)
    w_cw_vals  = np.full(resolucion, np.nan)
    w_ml_vals  = np.full(resolucion, np.nan)
    q_ml_prev  = None
    q_last_cw  = None

    # Indices donde graficamos convergencia: inicio, mitad, final
    idx_conv = [resolucion // 2]

    for i, delta in enumerate(delta_vals):

        M_cw = matriz_cw(delta)
        q_cw = q_from_M(M_cw)
        w_cw = w_from_q(q_cw)
        w_cw_vals[i] = w_cw * 10 if not np.isnan(w_cw) else np.nan #Calculo CW
        if q_valido(q_cw):
            q_last_cw = q_cw

        M_in, M_mid, M_close = matrices_ml(Z, delta)

        if usar_ml_prev and q_ml_prev is not None:
            q_guess = q_ml_prev 
        elif q_valido(q_cw):
            q_guess = q_cw
        else:
            q_guess = q_last_cw
#        elif q_last_cw is not None:
 #           q_guess = q_last_cw
  #      else:
   #         q_guess = _guess_safe()

        if not q_valido(q_guess):
            q_ml_prev = None
            continue

        # Guardar historial solo en los indices de interes
        guardar = i in idx_conv

        q_res, historial = _iterar(
            q_guess, M_in, M_mid, M_close,  #Aca te doy como guess el anterior o según haya salido
            kerr_fwd, kerr_bwd, modo,
            guardar_historial=guardar
        )

        # Grafico de convergencia para este delta
        if guardar and historial and len(historial) > 1:
            etiqueta = { resolucion//2: 'mitad', }[i]
            fig_c, ax_c = plt.subplots(figsize=(6, 3))
            ax_c.plot(historial, 'o-', ms=3, color='tomato')
            ax_c.axhline(historial[-1], ls='--', color='gray', lw=1)
            ax_c.set_xlabel('Iteracion')
            ax_c.set_ylabel(r'$w_0$ [mm]')
            ax_c.set_title(f'{nombre} — convergencia en delta={delta:.4f} ({etiqueta})\nZ={Z}')
            ax_c.grid(True, linestyle=':')
            plt.tight_layout()
            plt.show()

        if q_valido(q_res):
            w_ml_vals[i] = w_from_q(q_res) * 10
            q_ml_prev = q_res
        else:
            q_ml_prev = None

    return w_cw_vals, w_ml_vals
