#%% Cintura Vs Iteraciones

def graficar_cintura_vs_iteraciones(delta, Z, configs, titulo_general=''):
    """
    Grafica w0 en función de las iteraciones para un delta fijo y un Z dado.
    Hace un pequeño desplazamiento horizontal para que curvas superpuestas
    no queden totalmente tapadas.
    """
    fig, ax = plt.subplots(figsize=(8, 5))

    for j, (nombre, kfwd, kbwd, modo, ml_prev) in enumerate(configs):
        M_in, M_mid, M_close = matrices_ml(Z, delta)
        q_cw = q_from_M(matriz_cw(delta))

        if not q_valido(q_cw):
            print(f"{nombre}: q_CW inválido")
            continue

        q_res, historial = _iterar(
            q_cw, M_in, M_mid, M_close,
            kfwd, kbwd, modo,
            guardar_historial=True
        )

        if historial is None or len(historial) == 0:
            print(f"{nombre}: sin historial")
            continue

        x = np.arange(len(historial), dtype=float)
        x = x + 0.03 * j   # offset visual mínimo para evitar superposición total

        print(f"{nombre}: {len(historial)} puntos")

        ax.plot(
            x, historial,
            marker='o', ms=4, lw=1.6,
            label=nombre,
            zorder=10 - j
        )

    ax.set_xlabel('Iteración')
    ax.set_ylabel(r'$w_0$ [mm]')
    ax.set_title(
        f'{titulo_general}\n'
        f'delta = {delta:.3f} cm   |   Z = {Z:.3f} cm'
    )
    ax.grid(True, linestyle=':')
    ax.legend(fontsize=8)
    plt.tight_layout()
    plt.show()
    
